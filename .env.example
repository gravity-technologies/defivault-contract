# =============================================================================
# GRVT DeFi Vault - Environment Template
# =============================================================================
# This file stores network credentials only.
# Deployment inputs are defined in JSON5 parameter files under:
#   ignition/parameters/<environment>/*.json5
#
# Fresh proxy deployment example:
#   DEPLOY_PARAMS_FILE=ignition/parameters/sepolia/vault-core.json5 \
#   npx hardhat run scripts/deploy/deploy-vault-core.ts --network sepolia
# Post-deploy config example:
#   npx hardhat ignition deploy ./ignition/modules/VaultPrincipalTokenConfig.ts \
#     --network sepolia \
#     --parameters ignition/parameters/sepolia/principal-token-config.json5
# =============================================================================

# =============================================================================
# Network RPC Endpoints
# =============================================================================
# Sepolia RPC URL used by `network: sepolia` in hardhat.config.ts
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY


# =============================================================================
# Deployment Signer Keys
# =============================================================================
# Private key for deployments/operations on Sepolia.
# Format: 64 hex chars, NO 0x prefix (Hardhat config currently expects raw key).
SEPOLIA_PRIVATE_KEY=YOUR_PRIVATE_KEY_HEX_NO_0x


# =============================================================================
# Optional Verification Keys
# =============================================================================
# Add explorer API keys here if/when verify flows are enabled.
# ETHERSCAN_API_KEY=


# =============================================================================
# Optional Fork Testing
# =============================================================================
# MAINNET_RPC_URL=https://...
# MAINNET_FORK_BLOCK=22000000
