# Deployment environment: `staging`, `testnet`, or `production`.
GRVT_ENV=

# Sepolia RPC endpoint used by Hardhat.
SEPOLIA_RPC_URL=

# Sepolia deployment private key. Use a raw 64-hex string without `0x`.
SEPOLIA_PRIVATE_KEY=

# Mainnet RPC endpoint used by Hardhat.
MAINNET_RPC_URL=

# Mainnet deployment private key. Use a raw 64-hex string without `0x`.
MAINNET_PRIVATE_KEY=

# Optional explorer API key for contract verification.
ETHERSCAN_API_KEY=
