# =============================================================================
# GRVT DeFi Vault - Environment Template
# =============================================================================

# =============================================================================
# Network RPC Endpoints
# =============================================================================
# Ethereum Sepolia L1 RPC URL used by `network: sepolia` in hardhat.config.ts
ETHEREUM_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# =============================================================================
# Deployment Signer Keys
# =============================================================================
# Private key for deployments/operations on Ethereum Sepolia.
# Format: 64 hex chars, NO 0x prefix (Hardhat config currently expects raw key).
OPERATOR_PRIVATE_KEY=YOUR_PRIVATE_KEY_HEX_NO_0x

# =============================================================================
# Optional Verification Keys
# =============================================================================
# Add explorer API keys here before running `npm run verify:initial-stack`.
# If omitted, Hardhat verification falls back to any other enabled explorer
# integrations such as Sourcify.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# =============================================================================
# Optional Fork Testing
# =============================================================================
# MAINNET_RPC_URL=https://...
# MAINNET_FORK_BLOCK=22000000
