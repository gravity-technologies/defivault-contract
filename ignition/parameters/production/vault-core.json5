{
  VaultCoreModule: {
    // VAULT_ADMIN_ROLE holder and vault proxy admin owner; use governance or multisig.
    deployAdmin: "0x0000000000000000000000000000000000000000",
    // L1 BridgeHub for production.
    bridgeHub: "0x0000000000000000000000000000000000000000",
    // GRVT bridge-proxy fee token on production.
    grvtBridgeProxyFeeToken: "0x0000000000000000000000000000000000000000",
    // Fill with the real production L2 chain id; zero is an intentional placeholder.
    l2ChainId: "325n",
    // Fixed L2 recipient for production rebalance flows. Set separately from governance and treasury.
    l2ExchangeRecipient: "0x0000000000000000000000000000000000000000",
    // Canonical wrapped-native token on production.
    wrappedNativeToken: "0x0000000000000000000000000000000000000000",
    // Must be non-zero and must not equal deployAdmin.
    yieldRecipient: "0x0000000000000000000000000000000000000000",
  },
}
