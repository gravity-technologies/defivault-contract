{
  "name": "defivault",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test --network hardhatTest",
    "typecheck": "tsgo --noEmit",
    "compile": "hardhat compile",
    "size:contracts": "HARDHAT_BUILD_PROFILE=production hardhat contract-size list",
    "size:check:vault": "HARDHAT_BUILD_PROFILE=production hardhat contract-size list --no-compile",
    "check:all": "npm run clean && npm run compile && npm run size:check:vault && npm run typecheck && npm run format && npm run test",
    "clean": "hardhat clean",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,sol,json,json5,md,yml,yaml}\"",
    "slither": "bash scripts/slither.sh",
    "claim:failed-native-deposit": "hardhat ignition deploy ./ignition/modules/NativeBridgeGatewayClaimFailedDeposit.ts",
    "upgrade:native-bridge-gateway": "hardhat ignition deploy ./ignition/modules/NativeBridgeGatewayUpgrade.ts",
    "upgrade:vault": "hardhat ignition deploy ./ignition/modules/VaultUpgrade.ts",
    "upgrade:strategy": "hardhat ignition deploy ./ignition/modules/StrategyUpgrade.ts",
    "smoke:deployment": "hardhat run ./scripts/ci/deployment-smoke.ts --network localhost",
    "deploy:initial-stack:interactive": "hardhat run ./scripts/deploy/deploy-initial-stack-interactive.ts --network sepolia",
    "deploy:initial-stack:interactive:local": "hardhat run ./scripts/deploy/deploy-initial-stack-interactive.ts --network localhost",
    "registry:sync": "tsx ./scripts/deploy/sync-deployment-registry.ts",
    "report:treasury-vault-state": "tsx ./scripts/report/treasury-vault-state.ts",
    "verify:initial-stack": "tsx ./scripts/verify/verify-initial-stack.ts",
    "ops:strategy-allocation-smoke": "tsx ./scripts/ops/strategy-allocation-smoke.ts",
    "ops:allocate-to-strategy": "hardhat ignition deploy ./ignition/modules/VaultAllocateToStrategy.ts",
    "ops:deallocate-from-strategy": "hardhat ignition deploy ./ignition/modules/VaultDeallocateFromStrategy.ts",
    "ops:deallocate-all-from-strategy": "hardhat ignition deploy ./ignition/modules/VaultDeallocateAllFromStrategy.ts",
    "ops:emergency-native-to-l2": "hardhat ignition deploy ./ignition/modules/VaultEmergencyNativeToL2.ts",
    "ops:emergency-erc20-to-l2": "hardhat ignition deploy ./ignition/modules/VaultEmergencyErc20ToL2.ts",
    "yield-recipient:schedule-update": "hardhat ignition deploy ./ignition/modules/YieldRecipientScheduleUpdate.ts",
    "yield-recipient:execute-update": "hardhat ignition deploy ./ignition/modules/YieldRecipientExecuteUpdate.ts",
    "ops:harvest-yield": "hardhat ignition deploy ./ignition/modules/VaultHarvestYield.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.2",
    "@nomicfoundation/hardhat-utils": "^3.0.6",
    "@solidstate/hardhat-contract-sizer": "^3.0.0",
    "@types/node": "^22.19.11",
    "@typescript/native-preview": "^7.0.0-dev.20260304.1",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.2.1",
    "tsx": "^4.21.0",
    "viem": "^2.45.2"
  },
  "type": "module",
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "node-emoji": "^2.2.0",
    "ora": "^9.3.0"
  }
}
