{
  GhoClaimRewardsModule: {
    // Strategy proxy that should receive the Merkl reward claim.
    strategy: "0x0000000000000000000000000000000000000000",
    // Default Merkl API base for reward discovery.
    apiBase: "https://api.merkl.xyz",
    // Keep zero unless a minimum claim size is required.
    minClaimDelta: "0n",
    // Set true to print the claim plan without sending a transaction.
    dryRun: true,
  },
}
